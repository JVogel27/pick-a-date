# --- Server ---
PORT=3000
# Set to "production" to make the server serve the built client bundle (dist/client)
# and use PICK_DATA_DIR for persistent data. Leave as development for local dev.
NODE_ENV=development

# --- Data store ---
# Directory holding the writable date-ideas.json. Defaults to the bundled
# server/src/data dir (dev). In production set this to a persistent path outside
# the release dir so date history survives deploys, e.g. the box's shared/ dir.
# PICK_DATA_DIR=/srv/apps/pick-a-date/shared
